    "dotenv": "^16.4.5",
    "fast-glob": "^3.3.2",
    "inquirer": "^12.1.0",
    "marked": "^14.1.0",
    "marked-terminal": "^7.2.0",
    "openai": "^4.73.0",
    "ora": "^8.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
